# Required — used for AI decomposition (RFC → work units) and agent calls
ANTHROPIC_API_KEY=sk-ant-...

# Optional — only needed when using --linear flag
LINEAR_API_KEY=lin_api_...
LINEAR_TEAM_ID=               # Fallback for --team flag
LINEAR_LABEL=ralph-approved   # Fallback for --label flag

# Optional — only needed when using codex agent
OPENAI_API_KEY=sk-...
